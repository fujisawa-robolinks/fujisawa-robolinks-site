---
import BaseLayout from "../layouts/BaseLayout.astro";

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="藤沢ロボリンクス｜小学生向けロボットスポーツチーム"
  description="藤沢ロボリンクスは、神奈川県藤沢市で活動する小学生向けロボットスポーツチームです。ロボットづくりと対戦を通じて、楽しく学び、仲間と協力しながら成長する活動を行っています。"
  currentPath="/"
>
  <section class="hero">
    <div class="container">
      <img class="hero-badge" src={withBase("/assets/team-icon.png")} alt="藤沢ロボリンクス チームアイコン" width="320" height="320" />
      <h1>湘南の風と、<br />ロボットのひらめき。</h1>
      <p>藤沢ロボリンクスは、藤沢市を拠点に小中学生がロボットスポーツを楽しみながら、挑戦力とチームワークを育てるチームです。</p>
      <div class="hero-actions">
        <a class="btn" href={withBase("/activities")}>活動内容を見る</a>
        <a class="btn btn-sub" href="https://www.instagram.com/fujisawa_robolinks?igsh=MXMxNmJmNTdyZ24zZA==" target="_blank" rel="noreferrer">Instagramを見る</a>
      </div>

      <dl class="info-grid" aria-label="チーム基本情報">
        <div class="info-item">
          <dt>対象</dt>
          <dd>小学生・中学生</dd>
        </div>
        <div class="info-item">
          <dt>活動日</dt>
          <dd>月2回（第2・第4土曜日）</dd>
        </div>
        <div class="info-item">
          <dt>活動拠点</dt>
          <dd>藤沢駅近郊</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="section container">
    <article class="icon-feature">
      <img src={withBase("/assets/team-principle.png")} alt="藤沢ロボリンクス チーム理念イメージ" width="120" height="120" />
      <div>
        <h2>チーム理念</h2>
        <p class="lead">藤沢ロボリンクスは、「元気に、楽しく、礼儀正しく、みんなで楽しむロボットスポーツ」を大切にしています。自分が楽しむだけではなく、周りも楽しめるように声をかけ合い、協力しながら取り組んでいきます。</p>
      </div>
    </article>
  </section>

  <section class="section container">
    <h2>このサイトでわかること</h2>
    <div class="cards">
      <article class="card">
        <h3>活動スケジュール</h3>
        <p>第2・第4土曜日の活動サイクルと、日々の取り組み内容を掲載します。</p>
      </article>
      <article class="card">
        <h3>拠点とチーム方針</h3>
        <p>藤沢駅近郊を中心に、地域に根ざした育成方針を紹介します。</p>
      </article>
      <article class="card">
        <h3>SNS・大会レポート</h3>
        <p>Instagramの活動記録と、大会出場時のブログを確認できます。</p>
      </article>
    </div>
  </section>
</BaseLayout>
